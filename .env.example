# ArxPrism Environment Configuration
# Docker Network: All services communicate via Docker internal DNS

# =============================================================================
# LLM Configuration (OpenAI / OpenAI-Compatible)
# =============================================================================
# 统一使用 LLM_*（不再兼容 OPENAI_*）
LLM_PROVIDER=openai_compatible
LLM_API_KEY=sk-your-api-key-here
# 例如 OpenAI: https://api.openai.com/v1
# 例如第三方（OpenAI-compatible）: https://xxx/v1
LLM_BASE_URL=
# LLM Model Routing（chat/completions；与 Embeddings 配置独立）
LLM_TRIAGE_MODEL=sapiens-ai/agnes-1.5-lite
LLM_EXTRACTOR_MODEL=anthropic/claude-sonnet-4.6
LLM_RESOLUTION_MODEL=openai/gpt-5.4-mini
# 可选：仅 Embeddings 使用另一 base（部分网关对 /embeddings 误启 CSRF，而 /chat/completions 正常）
# 示例：LLM_BASE_URL=https://zenmux.ai/api/v1 时，可设 LLM_EMBEDDING_BASE_URL=https://api.openai.com/v1
LLM_EMBEDDING_BASE_URL=
# 可选：Embeddings 专用 key（留空则与 LLM_API_KEY 相同）
LLM_EMBEDDING_API_KEY=
LLM_EMBEDDING_MODEL=text-embedding-3-small
# Chat completions 单次输出上限（萃取主调用等）
LLM_MAX_TOKENS=8192

# =============================================================================
# Neo4j Configuration (Docker internal: neo4j:7687)
# =============================================================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# =============================================================================
# Redis Configuration (Docker internal: redis:6379)
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=production
LOG_LEVEL=INFO
# development 时开启 FastAPI /docs 与 /redoc；生产务必 production
ENVIRONMENT=development
# 浏览器可访问 API 的 Origin，逗号分隔（须含前端实际地址，勿用 *）
CORS_ORIGINS=http://localhost:3000,https://your-prod-domain.com

# 一键清空数据 API：POST /api/v1/admin/clear-all-data 时请求头 X-ArxPrism-Admin-Token 须与此一致；留空则禁用该接口
ADMIN_RESET_TOKEN=

# =============================================================================
# arXiv 抓取（Worker）
# =============================================================================
# 单次任务最多从 arXiv API 遍历多少条候选；前 N 篇已在库时会继续向后翻直到凑满任务「最大篇数」或触顶
ARXIV_MAX_SCAN_PER_TASK=500

# =============================================================================
# Service URLs (for internal Docker communication)
# =============================================================================
API_URL=http://api:8000
FRONTEND_URL=http://frontend:3000

# =============================================================================
# Supabase（Auth / profiles / system_settings；生产务必配置完整）
# =============================================================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Dashboard → Settings → API → JWT Secret（与 anon key 不同）。
# 若 access token 为 HS256 须填此项；若为 RS256/ES256（新版项目常见），后端从 SUPABASE_URL/auth/v1/certs 拉公钥，此项可空但 URL 必填且 API 容器需能访问外网。
SUPABASE_JWT_SECRET=
# 本地无 Supabase 时 true：后端以固定开发用户放行（勿用于生产）
AUTH_DISABLED=false
# 管理员：在 Supabase SQL Editor 更新 public.profiles（与 auth.users.id 一致），非 Auth 面板
# update public.profiles set role = 'admin' where id = '<auth.users 的 UUID>';

# =============================================================================
# Next.js Frontend Configuration
# =============================================================================
# Public API URL for Next.js (browser-accessible)
NEXT_PUBLIC_API_URL=http://localhost:8000
# 浏览器端 Supabase（与上方 SUPABASE_URL / SUPABASE_ANON_KEY 一致）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Docker Compose：NEXT_PUBLIC_* 在构建 frontend 时写入 bundle；未单独设置时会用 SUPABASE_URL / SUPABASE_ANON_KEY。
# 修改后须：docker compose build --no-cache frontend && docker compose up -d frontend

# Docker build: frontend base image (compose defaults to AWS Public ECR to avoid expired CN mirrors, e.g. hub-mirror.c.163.com TLS).
# Override if you use Docker Hub without a broken mirror:
# NODE_IMAGE=node:20-alpine

# =============================================================================
# PDF Storage Configuration
# =============================================================================
# 默认可写目录见 config（/tmp/arxprism-papers）。勿用 /data/... 除非目录已存在且对运行用户可写。
# PDF_STORAGE_PATH=/var/lib/arxprism/papers
