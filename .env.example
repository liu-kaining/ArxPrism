# ArxPrism Environment Configuration
# Docker Network: All services communicate via Docker internal DNS

# =============================================================================
# LLM Configuration (OpenAI / OpenAI-Compatible)
# =============================================================================
# 统一使用 LLM_*（不再兼容 OPENAI_*）
LLM_PROVIDER=openai_compatible
LLM_API_KEY=sk-your-api-key-here
# 例如 OpenAI: https://api.openai.com/v1
# 例如第三方（OpenAI-compatible）: https://xxx/v1
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini

# =============================================================================
# Neo4j Configuration (Docker internal: neo4j:7687)
# =============================================================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# =============================================================================
# Redis Configuration (Docker internal: redis:6379)
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=production
LOG_LEVEL=INFO

# =============================================================================
# Service URLs (for internal Docker communication)
# =============================================================================
API_URL=http://api:8000
FRONTEND_URL=http://frontend:3000

# =============================================================================
# Next.js Frontend Configuration
# =============================================================================
# Public API URL for Next.js (browser-accessible)
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# PDF Storage Configuration
# =============================================================================
PDF_STORAGE_PATH=/data/papers
